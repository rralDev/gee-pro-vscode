{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": ["ES2020", "dom"],
        "sourceMap": true,
        "strict": true,
        "rootDir": "src",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0",
        "types": ["node"]
    },
    "exclude": ["node_modules", ".vscode-test"]
}
